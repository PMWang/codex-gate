{
  "name": "codex-gate",
  "version": "0.2.0",
  "description": "A quality gate that keeps Codex honest — blocks AI-slop changes before they merge.",
  "keywords": [
    "codex",
    "openai",
    "ai",
    "agent",
    "quality-gate",
    "ci",
    "ai-slop",
    "code-review"
  ],
  "license": "MIT",
  "author": "PMWang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PMWang/codex-gate.git"
  },
  "homepage": "https://github.com/PMWang/codex-gate#readme",
  "bugs": {
    "url": "https://github.com/PMWang/codex-gate/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "codex-gate": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/cli.js",
    "test": "tsx --test 'src/**/*.test.ts'",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
